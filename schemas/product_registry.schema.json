{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Product card registry item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "status",
    "name",
    "keyword",
    "category",
    "card_path",
    "mandatory_attributes",
    "optional_attributes",
    "synonyms",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^prd_[a-z0-9_]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "approved",
        "deprecated"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "keyword": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "card_path": {
      "type": "string",
      "pattern": "^cards/.+\\.md$"
    },
    "mandatory_attributes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "optional_attributes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "synonyms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
